---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Visor GeoJSON / KML / SHP · Herramientas · GeoHub Chile"
  description="Visualiza al instante archivos .geojson, .kml, .kmz y shapefile en tu navegador. 100% client-side, sin servidor."
>
  <Header />

  <!-- Librerías client-side (mismas que ya usa el visor de riesgos) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.Default.min.css" />
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/leaflet.markercluster.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/togeojson/0.16.0/togeojson.min.js"></script>
  <script is:inline src="https://unpkg.com/shpjs@4.0.4/dist/shp.min.js"></script>

  <div class="herr-page">
    <div class="herr-back">
      <a href={`${base}/herramientas/`}>← Herramientas</a>
    </div>

    <div class="herr-hdr">
      <h1>🗺️ Visor de archivos geográficos</h1>
      <p>
        Carga un archivo <code>.geojson</code>, <code>.kml</code>,
        <code>.kmz</code> o un shapefile comprimido (<code>.zip</code>) y
        visualízalo al instante. Útil para inspeccionar capas sin abrir QGIS.
        <strong>Todo ocurre en tu navegador</strong> — los archivos no se
        suben a ningún servidor.
      </p>
    </div>

    <!-- Drop zone -->
    <label class="dropzone" id="dropzone">
      <input type="file" id="file-input" accept=".geojson,.json,.kml,.kmz,.zip" />
      <div class="dz-main">
        <div class="dz-icon">📂</div>
        <div class="dz-text">
          Arrastra un archivo aquí o <strong>haz clic para elegir</strong>
        </div>
        <div class="dz-formats">
          Formatos: .geojson · .json · .kml · .kmz · .zip (shapefile)
        </div>
        <div class="dz-limits">
          Tamaño recomendado: <strong>≤ 50 MB</strong> GeoJSON ·
          <strong>≤ 10 MB</strong> KML/KMZ ·
          <strong>≤ 30 MB</strong> Shapefile.
          Sin límite duro — depende de la RAM disponible en tu navegador.
        </div>
      </div>
    </label>

    <details class="dz-help">
      <summary>¿No sabes qué archivo subir? Mira aquí ↓</summary>
      <div class="dz-help-content">
        <div class="dz-help-item">
          <strong>.geojson</strong> o <strong>.json</strong>
          <p>
            Es un archivo de texto con coordenadas y datos. Es el formato más usado
            en aplicaciones web modernas. Lo exportan programas como
            <em>QGIS</em>, <em>ArcGIS</em>, <em>Mapshaper</em> o el editor en línea
            <em>geojson.io</em>.
          </p>
        </div>
        <div class="dz-help-item">
          <strong>.kml</strong> o <strong>.kmz</strong>
          <p>
            Es lo que exporta <em>Google Earth</em> y <em>Google My Maps</em>.
            Si dibujaste un punto o área en Google Earth Pro y le diste "Guardar
            lugar como…", obtienes uno de estos. KMZ es simplemente un KML
            comprimido.
          </p>
        </div>
        <div class="dz-help-item">
          <strong>.zip (shapefile)</strong>
          <p>
            El formato clásico de los sistemas de información geográfica. Un
            shapefile son varios archivos juntos (<code>.shp</code>,
            <code>.dbf</code>, <code>.shx</code>, <code>.prj</code>). Antes de
            subirlo aquí, comprime todos esos archivos en un único
            <code>.zip</code>.
          </p>
        </div>
        <div class="dz-help-item">
          <strong>¿Tengo un Excel, CSV o PDF?</strong>
          <p>
            Este visor no los lee directamente. Si tienes coordenadas en un
            CSV, podemos agregar esa función — abre un issue en GitHub
            describiendo tu caso.
          </p>
        </div>
      </div>
    </details>

    <div id="status" class="status"></div>

    <!-- Resultado: panel de info + mapa + tabla de propiedades -->
    <div id="resultado" class="resultado" style="display:none">
      <div class="resumen">
        <div class="resumen-grid">
          <div><span class="r-lbl">Archivo</span><span class="r-val" id="r-archivo">—</span></div>
          <div><span class="r-lbl">Formato detectado</span><span class="r-val" id="r-formato">—</span></div>
          <div><span class="r-lbl">Features</span><span class="r-val" id="r-features">—</span></div>
          <div><span class="r-lbl">Geometrías</span><span class="r-val" id="r-geoms">—</span></div>
          <div class="r-bounds"><span class="r-lbl">Bounds (WGS84)</span><span class="r-val" id="r-bounds">—</span></div>
        </div>
        <div class="resumen-actions">
          <button id="btn-descargar" class="btn-tool">⬇ Descargar como GeoJSON</button>
          <button id="btn-copiar" class="btn-tool">📋 Copiar GeoJSON</button>
          <button id="btn-limpiar" class="btn-tool btn-tool-ghost">✕ Limpiar</button>
        </div>
      </div>

      <div id="mapa-canvas" class="mapa-tool"></div>

      <details class="props-wrap" open>
        <summary>📋 Tabla de propiedades (primeros 50 features)</summary>
        <div id="tabla-wrap" class="tabla-wrap"></div>
      </details>
    </div>
  </div>

  <Footer />
</Base>

<style>
  .herr-page {
    max-width: 1280px; margin: 0 auto;
    padding: 1.5rem 1.5rem 4rem;
  }
  .herr-back a {
    font-family: var(--mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: 1px;
    color: var(--t3); text-decoration: none;
    transition: color 0.15s;
  }
  .herr-back a:hover { color: var(--verde); }
  .herr-hdr {
    margin: 1.5rem 0 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .herr-hdr h1 {
    font-size: 1.6rem; font-weight: 700;
    color: var(--t1); margin-bottom: 0.5rem;
    letter-spacing: -0.015em;
  }
  .herr-hdr p {
    color: var(--t2); font-size: 13.5px;
    line-height: 1.7; max-width: 78ch;
  }
  .herr-hdr code {
    background: var(--surface2); border: 1px solid var(--border);
    padding: 1px 5px; border-radius: 4px;
    font-family: var(--mono); font-size: 11.5px;
    color: var(--verde);
  }
  .herr-hdr strong { color: var(--t1); }

  /* Drop zone */
  .dropzone {
    display: block; cursor: pointer;
    background: var(--surface);
    border: 2px dashed var(--border2);
    border-radius: var(--r);
    padding: 2.5rem 1.5rem;
    text-align: center;
    transition: all 0.18s ease;
    margin-bottom: 1rem;
  }
  .dropzone:hover, .dropzone.drag {
    border-color: var(--verde);
    background: var(--verde-glow);
  }
  .dropzone input { display: none; }
  .dz-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .dz-text { font-size: 14px; color: var(--t1); }
  .dz-text strong { color: var(--verde); }
  .dz-formats { font-size: 11.5px; color: var(--t3); margin-top: 0.5rem; font-family: var(--mono); }
  .dz-limits {
    font-size: 11px; color: var(--t3);
    margin-top: 0.6rem; line-height: 1.6;
    max-width: 56ch; margin-left: auto; margin-right: auto;
  }
  .dz-limits strong { color: var(--t2); font-weight: 600; }

  /* Status (mensajes ricos: título + cuerpo + sugerencia) */
  .status:empty { display: none; }
  .status {
    padding: 0.85rem 1rem;
    background: var(--surface2); border: 1px solid var(--border);
    border-left: 3px solid var(--border2);
    border-radius: var(--r); margin-bottom: 1rem;
  }
  .status-title {
    font-size: 13.5px; font-weight: 600;
    color: var(--t1); line-height: 1.4;
  }
  .status-body {
    margin-top: 0.4rem;
    font-size: 12.5px; color: var(--t2);
    line-height: 1.65; max-width: 80ch;
  }
  .status-hint {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--border);
    font-size: 12px; color: var(--t3);
    line-height: 1.6;
  }
  .status.error {
    background: rgba(230,57,70,0.06);
    border-color: rgba(230,57,70,0.2);
    border-left-color: #e63946;
  }
  .status.error .status-title { color: #ff8a92; }
  .status.error .status-body { color: #d9b4b8; }
  .status.error .status-hint { color: #b59a9c; }
  .status.success {
    background: rgba(61,214,140,0.05);
    border-color: var(--verde-dim);
    border-left-color: var(--verde);
  }
  .status.success .status-title { color: var(--verde); }
  .status.success .status-body { color: var(--t2); }

  /* Help expandible bajo el dropzone */
  .dz-help {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
    margin-bottom: 1rem;
  }
  .dz-help summary {
    padding: 0.7rem 1rem;
    cursor: pointer;
    font-family: var(--mono); font-size: 12px;
    color: var(--t2); user-select: none;
    list-style: none;
  }
  .dz-help summary::-webkit-details-marker { display: none; }
  .dz-help summary:hover { color: var(--verde); }
  .dz-help[open] summary {
    border-bottom: 1px solid var(--border);
    color: var(--t1);
  }
  .dz-help-content {
    padding: 1rem 1.25rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem 1.5rem;
  }
  .dz-help-item strong {
    color: var(--verde); font-size: 13px;
    font-family: var(--mono);
  }
  .dz-help-item code {
    background: var(--surface2); border: 1px solid var(--border);
    padding: 0px 4px; border-radius: 3px;
    font-family: var(--mono); font-size: 10.5px;
    color: var(--verde);
  }
  .dz-help-item em {
    color: var(--t1); font-style: normal;
    font-weight: 500;
  }
  .dz-help-item p {
    margin-top: 0.3rem;
    font-size: 12px; color: var(--t2);
    line-height: 1.65;
  }

  /* Resumen */
  .resultado { display: flex; flex-direction: column; gap: 1rem; }
  .resumen {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r); padding: 1rem 1.25rem;
  }
  .resumen-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.85rem 1.25rem;
    padding-bottom: 0.85rem;
    margin-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
  }
  .resumen-grid > div { display: flex; flex-direction: column; gap: 0.15rem; }
  .r-bounds { grid-column: 1 / -1; }
  .r-lbl {
    font-family: var(--mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: 1px;
    color: var(--t3);
  }
  .r-val {
    font-family: var(--mono); font-size: 13px;
    color: var(--t1); word-break: break-all;
  }
  .resumen-actions {
    display: flex; gap: 0.5rem; flex-wrap: wrap;
  }
  .btn-tool {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--t1);
    padding: 0.45rem 0.9rem;
    border-radius: 6px;
    font-family: var(--sans);
    font-size: 12.5px; font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-tool:hover {
    border-color: var(--verde-dim);
    color: var(--verde);
    background: var(--verde-glow);
  }
  .btn-tool-ghost { color: var(--t3); }
  .btn-tool-ghost:hover {
    color: #e63946; border-color: rgba(230,57,70,0.4);
    background: rgba(230,57,70,0.08);
  }

  /* Mapa */
  .mapa-tool {
    height: 520px;
    border: 1px solid var(--border);
    border-radius: var(--r);
    background: var(--surface);
    overflow: hidden;
  }

  /* Tabla */
  .props-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
  }
  .props-wrap summary {
    padding: 0.7rem 1rem;
    cursor: pointer;
    font-family: var(--mono); font-size: 12px;
    color: var(--t2);
    user-select: none;
  }
  .props-wrap[open] summary {
    border-bottom: 1px solid var(--border);
  }
  .tabla-wrap {
    max-height: 360px;
    overflow: auto;
  }
  .tabla-wrap table {
    width: 100%; border-collapse: collapse;
    font-size: 11.5px; font-family: var(--mono);
  }
  .tabla-wrap th, .tabla-wrap td {
    padding: 6px 10px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    color: var(--t2);
  }
  .tabla-wrap th {
    position: sticky; top: 0;
    background: var(--surface2);
    color: var(--t1);
    font-weight: 600; font-size: 10.5px;
    text-transform: uppercase; letter-spacing: 0.5px;
    z-index: 1;
  }
  .tabla-wrap tr:hover td { background: var(--surface2); }
  .tabla-vacia {
    padding: 1.5rem;
    text-align: center;
    color: var(--t3);
    font-family: var(--mono);
    font-size: 12px;
  }

</style>

<!-- ════════════════════════════════════════════════════════════════
     ESTILOS GLOBALES PARA LEAFLET
     Astro scopea los <style> por defecto, pero Leaflet inyecta sus
     elementos en runtime — por eso necesitan ser is:global o nunca
     aplicarán.
══════════════════════════════════════════════════════════════════ -->
<style is:global>
  /* Popups dark theme */
  .leaflet-popup-content-wrapper {
    background: #131920 !important;
    color: #e8f0fe !important;
    border: 1px solid #2d4155 !important;
    border-radius: 6px !important;
    box-shadow: 0 6px 20px rgba(0,0,0,0.55) !important;
  }
  .leaflet-popup-tip {
    background: #131920 !important;
    border: 1px solid #2d4155 !important;
    box-shadow: none !important;
  }
  .leaflet-popup-content {
    margin: 10px 14px !important;
    color: #e8f0fe !important;
    line-height: 1.5 !important;
    font-family: 'Courier New', monospace;
    font-size: 11.5px;
  }
  .leaflet-popup-content table {
    border-collapse: collapse;
    width: 100%;
  }
  .leaflet-popup-content table td {
    padding: 3px 6px 3px 0;
    vertical-align: top;
    word-break: break-word;
  }
  .leaflet-popup-content table td:first-child {
    color: #8fa3bf;     /* claves: gris suave */
    font-weight: 500;
    white-space: nowrap;
  }
  .leaflet-popup-content table td:last-child {
    color: #e8f0fe;     /* valores: blanco crema */
  }
  .leaflet-popup-content a.popup-link {
    color: #2cd4e0 !important;
    text-decoration: underline;
    text-decoration-color: rgba(44,212,224,0.4);
    text-underline-offset: 2px;
    word-break: break-all;
  }
  .leaflet-popup-content a.popup-link:hover {
    color: #5ee0eb !important;
    text-decoration-color: #2cd4e0;
  }
  .leaflet-container a.leaflet-popup-close-button {
    color: #8fa3bf !important;
    font-size: 18px !important;
    padding: 6px 8px 0 0 !important;
  }
  .leaflet-container a.leaflet-popup-close-button:hover {
    color: #e8f0fe !important;
    background: transparent !important;
  }
  /* Controles de zoom */
  .leaflet-control-zoom a {
    background: #131920 !important;
    color: #e8f0fe !important;
    border: 1px solid #21303f !important;
  }
  .leaflet-control-zoom a:hover {
    background: #1a2230 !important;
    color: #3dd68c !important;
    border-color: #239960 !important;
  }
  /* Attribution */
  .leaflet-control-attribution {
    background: rgba(13,17,23,0.85) !important;
    color: #4a6580 !important;
    font-size: 10px !important;
  }
  .leaflet-control-attribution a {
    color: #8fa3bf !important;
  }
  /* Clusters — tonos cian coherentes con el tema */
  .marker-cluster {
    background: rgba(44,212,224,0.18) !important;
  }
  .marker-cluster div {
    background: rgba(44,212,224,0.55) !important;
    color: #06121a !important;
    font-weight: 700 !important;
    font-family: 'IBM Plex Mono', monospace !important;
    font-size: 11px !important;
  }
  .marker-cluster-small div { background: rgba(61,214,140,0.65) !important; }
  .marker-cluster-medium div { background: rgba(244,130,10,0.7) !important; color: #06121a !important; }
  .marker-cluster-large div { background: rgba(230,57,70,0.75) !important; color: #fff !important; }
</style>

<script is:inline>
  (() => {
    const $ = (id) => document.getElementById(id);
    const dropzone = $('dropzone');
    const fileInput = $('file-input');
    const status = $('status');
    const resultado = $('resultado');

    let map = null;
    let layer = null;
    let clusterLayer = null;
    let geojsonActual = null;
    let nombreActual = '';

    function escapar(s) {
      return String(s).replace(/[&<>"']/g, m =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m])
      );
    }

    // Mensaje rico: { title, body?, hint? } + tipo (success/error)
    function setStatus(msgOrTitle, clase = '', body = '', hint = '') {
      if (!msgOrTitle) {
        status.innerHTML = '';
        status.className = 'status';
        return;
      }
      // Si llaman con objeto, desestructurar
      let title = msgOrTitle, type = clase;
      if (typeof msgOrTitle === 'object') {
        title = msgOrTitle.title;
        body  = msgOrTitle.body  || '';
        hint  = msgOrTitle.hint  || '';
        type  = msgOrTitle.type  || clase;
      }
      const parts = [`<div class="status-title">${escapar(title)}</div>`];
      if (body) parts.push(`<div class="status-body">${escapar(body)}</div>`);
      if (hint) parts.push(`<div class="status-hint">💡 ${escapar(hint)}</div>`);
      status.innerHTML = parts.join('');
      status.className = 'status' + (type ? ' ' + type : '');
    }

    // ─── Parsers ───
    async function parsearArchivo(file) {
      const nombre = file.name.toLowerCase();

      if (nombre.endsWith('.geojson') || nombre.endsWith('.json')) {
        const txt = await file.text();
        const data = JSON.parse(txt);
        const fc = normalizarGeoJSON(data);
        return { formato: 'GeoJSON', geojson: fc };
      }

      if (nombre.endsWith('.kml')) {
        if (!window.toGeoJSON) throw libNoCargada('procesar KML');
        const txt = await file.text();
        const xml = new DOMParser().parseFromString(txt, 'text/xml');
        return { formato: 'KML', geojson: window.toGeoJSON.kml(xml) };
      }

      if (nombre.endsWith('.kmz')) {
        if (!window.JSZip || !window.toGeoJSON) throw libNoCargada('procesar KMZ');
        const zip = await window.JSZip.loadAsync(await file.arrayBuffer());
        const kmlEntry = Object.values(zip.files)
          .find(f => !f.dir && f.name.toLowerCase().endsWith('.kml'));
        if (!kmlEntry) {
          throw new ErrorAmigable(
            'Este KMZ está vacío por dentro.',
            'Un archivo .kmz es básicamente un .zip que adentro debe traer un archivo .kml con los datos del mapa. El que subiste no contiene ese .kml interno, así que no hay nada para leer.',
            'Si lo exportaste de Google Earth, prueba abrirlo allá primero para verificar que tiene contenido. Si el archivo se ve corrupto, vuelve a exportarlo.'
          );
        }
        const txt = await kmlEntry.async('string');
        const xml = new DOMParser().parseFromString(txt, 'text/xml');
        return { formato: 'KMZ', geojson: window.toGeoJSON.kml(xml) };
      }

      if (nombre.endsWith('.zip')) {
        if (!window.shp) throw libNoCargada('procesar shapefile');
        let result;
        try {
          result = await window.shp(await file.arrayBuffer());
        } catch (e) {
          throw new ErrorAmigable(
            'No pude leer el shapefile dentro del .zip.',
            'Un shapefile son varios archivos (.shp, .dbf, .shx, .prj) que deben venir todos juntos dentro del .zip. Probablemente falta alguno o el .zip contiene otra cosa.',
            'Verifica que tu .zip contenga al menos los archivos .shp, .dbf y .shx (idealmente también .prj con el sistema de referencia).'
          );
        }
        // shpjs devuelve un FC o array de FC si hay múltiples .shp
        if (Array.isArray(result)) {
          return {
            formato: `Shapefile (${result.length} capas)`,
            geojson: {
              type: 'FeatureCollection',
              features: result.flatMap(fc => fc.features),
            },
          };
        }
        return { formato: 'Shapefile', geojson: result };
      }

      throw new ErrorAmigable(
        'No reconozco ese tipo de archivo.',
        `Recibí "${file.name}", pero por ahora solo entiendo formatos geoespaciales estándar: GeoJSON (.geojson o .json), KML/KMZ (los que exporta Google Earth) y shapefile comprimido en .zip (el típico de QGIS o ArcGIS).`,
        'Si tienes datos en Excel, CSV o PDF, primero hay que convertirlos a uno de estos formatos. Mira la sección "¿No sabes qué archivo subir?" arriba para más detalles.'
      );
    }

    // Error con contexto: title + body + hint para mostrar al usuario
    class ErrorAmigable extends Error {
      constructor(title, body, hint) {
        super(title);
        this.amigable = true;
        this.title = title; this.body = body; this.hint = hint;
      }
    }
    function libNoCargada(qué) {
      return new ErrorAmigable(
        `No pude cargar las librerías para ${qué}.`,
        'El visor necesita descargar 3 pequeñas librerías desde internet (Leaflet, JSZip, togeojson o shpjs). Una de ellas no llegó a cargar — probablemente un problema temporal de red o un bloqueador de scripts.',
        'Refresca la página con Ctrl+F5. Si persiste, revisa si tienes un bloqueador de anuncios o scripts (uBlock, NoScript, Brave Shields) activo y desactívalo solo para este sitio.'
      );
    }

    function normalizarGeoJSON(data) {
      if (data?.type === 'FeatureCollection') return data;
      if (data?.type === 'Feature') return { type: 'FeatureCollection', features: [data] };
      if (data?.type && data?.coordinates) {
        return { type: 'FeatureCollection', features: [{ type: 'Feature', geometry: data, properties: {} }] };
      }
      throw new ErrorAmigable(
        'El archivo es un JSON pero no un GeoJSON.',
        'GeoJSON es un tipo específico de JSON que debe tener una propiedad "type" con valor "FeatureCollection", "Feature" o el nombre de una geometría (Point, Polygon, etc.). El archivo que subiste es JSON válido pero no sigue esta estructura.',
        'Si lo exportaste desde un sistema, busca la opción "exportar como GeoJSON" en lugar de "JSON genérico". Para ver un ejemplo de cómo debería verse, visita geojson.org.'
      );
    }

    // ─── Render ───
    function inicializarMapaSiHaceFalta() {
      if (map) return;
      map = L.map('mapa-canvas', {
        center: [-37, -71], zoom: 4,
        zoomControl: false, worldCopyJump: true,
      });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '© OpenStreetMap · © CARTO',
        subdomains: 'abcd', maxZoom: 18, noWrap: true,
      }).addTo(map);
      L.control.zoom({ position: 'topright' }).addTo(map);
    }

    // Construye el HTML de un popup. Detecta URLs y las hace clicables.
    function popupHtml(props) {
      const entries = Object.entries(props || {});
      if (entries.length === 0) {
        return '<div style="color:#8fa3bf;font-style:italic">(sin propiedades)</div>';
      }
      const filas = entries.slice(0, 14).map(([k, v]) => {
        const valStr = String(v ?? '');
        let valHtml;
        if (/^https?:\/\//i.test(valStr)) {
          const acortado = valStr.length > 45 ? valStr.slice(0, 42) + '…' : valStr;
          valHtml = `<a class="popup-link" href="${escapar(valStr)}" target="_blank" rel="noopener">${escapar(acortado)} ↗</a>`;
        } else if (valStr === '' || valStr === 'null' || valStr === 'undefined') {
          valHtml = '<span style="color:#4a6580">—</span>';
        } else {
          valHtml = escapar(valStr.length > 80 ? valStr.slice(0, 78) + '…' : valStr);
        }
        return `<tr><td>${escapar(k)}</td><td>${valHtml}</td></tr>`;
      }).join('');
      const masFilas = entries.length > 14
        ? `<tr><td colspan="2" style="color:#4a6580;padding-top:6px;font-style:italic">+${entries.length - 14} propiedades más (descarga el GeoJSON para verlas)</td></tr>`
        : '';
      return `<table>${filas}${masFilas}</table>`;
    }

    function renderMapa(geojson) {
      inicializarMapaSiHaceFalta();
      // Limpiar capas previas
      if (layer) { layer.remove(); layer = null; }
      if (clusterLayer) { clusterLayer.remove(); clusterLayer = null; }

      const features = geojson.features || [];
      const puntos = features.filter(f =>
        f.geometry?.type === 'Point' || f.geometry?.type === 'MultiPoint'
      );
      const otros = features.filter(f =>
        f.geometry?.type !== 'Point' && f.geometry?.type !== 'MultiPoint'
      );

      const POPUP_OPTS = { maxWidth: 360, minWidth: 220, autoPanPadding: [40, 40] };
      const allBounds = L.latLngBounds([]);

      // Polígonos / líneas → capa normal
      if (otros.length > 0) {
        layer = L.geoJSON(
          { type: 'FeatureCollection', features: otros },
          {
            style: () => ({
              color: '#2cd4e0', weight: 2,
              fillColor: '#2cd4e0', fillOpacity: 0.15,
            }),
            onEachFeature: (feat, lyr) => {
              lyr.bindPopup(popupHtml(feat.properties), POPUP_OPTS);
            },
          }
        ).addTo(map);
        const b = layer.getBounds();
        if (b.isValid()) allBounds.extend(b);
      }

      // Puntos → cluster si son muchos, marcador simple si son pocos
      if (puntos.length > 0) {
        const usarCluster = puntos.length > 50 && window.L?.markerClusterGroup;
        clusterLayer = usarCluster
          ? L.markerClusterGroup({
              showCoverageOnHover: false,
              spiderfyOnMaxZoom: true,
              maxClusterRadius: 55,
              chunkedLoading: true,
            })
          : L.featureGroup();

        L.geoJSON(
          { type: 'FeatureCollection', features: puntos },
          {
            pointToLayer: (_f, latlng) =>
              L.circleMarker(latlng, {
                radius: 6, color: '#2cd4e0', weight: 2,
                fillColor: '#2cd4e0', fillOpacity: 0.65,
              }),
            onEachFeature: (feat, lyr) => {
              lyr.bindPopup(popupHtml(feat.properties), POPUP_OPTS);
            },
          }
        ).eachLayer(l => clusterLayer.addLayer(l));

        clusterLayer.addTo(map);
        const b = clusterLayer.getBounds();
        if (b.isValid()) allBounds.extend(b);
      }

      if (allBounds.isValid()) {
        map.fitBounds(allBounds, { padding: [20, 20], maxZoom: 14 });
        return allBounds;
      }
      return null;
    }

    function calcularResumen(geojson) {
      const feats = geojson.features || [];
      const tipos = {};
      feats.forEach(f => {
        const t = f.geometry?.type || 'sin-geometria';
        tipos[t] = (tipos[t] || 0) + 1;
      });
      const geomsStr = Object.entries(tipos)
        .map(([k, v]) => `${k}(${v})`)
        .join(' · ') || '—';
      return { total: feats.length, geomsStr };
    }

    function renderTabla(geojson) {
      const cont = $('tabla-wrap');
      const feats = (geojson.features || []).slice(0, 50);
      if (feats.length === 0) {
        cont.innerHTML = '<div class="tabla-vacia">Sin features con propiedades.</div>';
        return;
      }
      const cols = Array.from(new Set(feats.flatMap(f => Object.keys(f.properties || {})))).slice(0, 12);
      if (cols.length === 0) {
        cont.innerHTML = '<div class="tabla-vacia">Los features no tienen propiedades.</div>';
        return;
      }
      const head = '<tr><th>#</th>' + cols.map(c => `<th>${escapar(c)}</th>`).join('') + '<th>geometría</th></tr>';
      const rows = feats.map((f, i) => {
        const tds = cols.map(c => `<td>${escapar(String(f.properties?.[c] ?? ''))}</td>`).join('');
        return `<tr><td style="color:#4a6580">${i + 1}</td>${tds}<td style="color:#4a6580">${escapar(f.geometry?.type || '—')}</td></tr>`;
      }).join('');
      const totalFeats = geojson.features?.length || 0;
      const footer = totalFeats > 50
        ? `<div class="tabla-vacia">Mostrando 50 de ${totalFeats} features.</div>`
        : '';
      cont.innerHTML = `<table>${head}${rows}</table>${footer}`;
    }

    async function manejarArchivo(file) {
      if (!file) return;
      setStatus(`Procesando ${file.name}…`);
      resultado.style.display = 'none';
      try {
        const { formato, geojson } = await parsearArchivo(file);
        if (!geojson.features || geojson.features.length === 0) {
          setStatus({
            title: 'No encontré nada para dibujar en el mapa.',
            body:
              'Tu archivo se leyó correctamente, pero no contiene "features" — el nombre técnico para los elementos que un mapa puede mostrar: puntos, líneas o áreas. Lo más probable es que el archivo solo tenga estilos, metadatos o carpetas vacías, sin geometrías reales adentro.',
            hint:
              'Ábrelo en Google Earth o QGIS y verifica que veas algo dibujado (un alfiler, una línea o un polígono). Si lo ves vacío allá también, hay que crear las geometrías antes de exportar.',
            type: 'error',
          });
          return;
        }
        geojsonActual = geojson;
        nombreActual = file.name.replace(/\.[^.]+$/, '');
        const { total, geomsStr } = calcularResumen(geojson);

        $('r-archivo').textContent = file.name;
        $('r-formato').textContent = formato;
        $('r-features').textContent = total;
        $('r-geoms').textContent = geomsStr;

        resultado.style.display = 'flex';
        // Forzar layout antes de inicializar mapa
        await new Promise(r => requestAnimationFrame(r));
        const bounds = renderMapa(geojson);
        if (bounds) {
          const sw = bounds.getSouthWest(), ne = bounds.getNorthEast();
          $('r-bounds').textContent =
            `${sw.lng.toFixed(4)}, ${sw.lat.toFixed(4)} → ${ne.lng.toFixed(4)}, ${ne.lat.toFixed(4)}`;
        } else {
          $('r-bounds').textContent = '—';
        }
        renderTabla(geojson);
        setStatus({
          title: `✓ ${total} elemento${total === 1 ? '' : 's'} cargado${total === 1 ? '' : 's'} correctamente.`,
          body: `Mira el mapa de abajo para visualizar tu archivo. Puedes hacer clic sobre cada elemento para ver sus propiedades.`,
          type: 'success',
        });
      } catch (e) {
        console.error(e);
        if (e?.amigable) {
          setStatus({ title: e.title, body: e.body, hint: e.hint, type: 'error' });
        } else {
          setStatus({
            title: 'Algo salió mal al procesar el archivo.',
            body:
              'El archivo no se pudo leer correctamente. Esto puede pasar si el archivo está corrupto, mal formado, o si tiene un formato que el visor aún no soporta del todo. Detalle técnico: ' + (e?.message || e),
            hint:
              'Si el archivo se ve bien en QGIS o Google Earth pero acá no funciona, ayúdanos a mejorar el visor: abre un issue en GitHub con una descripción y, si es posible, el archivo adjunto.',
            type: 'error',
          });
        }
      }
    }

    // ─── Eventos ───
    fileInput.addEventListener('change', e => manejarArchivo(e.target.files?.[0]));

    ['dragenter', 'dragover'].forEach(ev =>
      dropzone.addEventListener(ev, e => { e.preventDefault(); dropzone.classList.add('drag'); })
    );
    ['dragleave', 'drop'].forEach(ev =>
      dropzone.addEventListener(ev, e => { e.preventDefault(); dropzone.classList.remove('drag'); })
    );
    dropzone.addEventListener('drop', e => {
      const f = e.dataTransfer?.files?.[0];
      if (f) manejarArchivo(f);
    });

    $('btn-descargar').addEventListener('click', () => {
      if (!geojsonActual) return;
      const blob = new Blob([JSON.stringify(geojsonActual, null, 2)], { type: 'application/geo+json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${nombreActual || 'archivo'}.geojson`;
      a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    });

    $('btn-copiar').addEventListener('click', async () => {
      if (!geojsonActual) return;
      try {
        await navigator.clipboard.writeText(JSON.stringify(geojsonActual, null, 2));
        setStatus({
          title: '✓ GeoJSON copiado al portapapeles.',
          type: 'success',
        });
        setTimeout(() => setStatus(''), 2500);
      } catch {
        setStatus({
          title: 'No pude copiar al portapapeles.',
          body: 'Tu navegador bloqueó el acceso al portapapeles. Esto suele pasar en pestañas en modo privado o cuando el sitio no se ve como "seguro".',
          hint: 'Usa el botón "⬇ Descargar como GeoJSON" como alternativa — funciona en cualquier navegador.',
          type: 'error',
        });
      }
    });

    $('btn-limpiar').addEventListener('click', () => {
      if (layer) { layer.remove(); layer = null; }
      if (clusterLayer) { clusterLayer.remove(); clusterLayer = null; }
      geojsonActual = null;
      nombreActual = '';
      fileInput.value = '';
      resultado.style.display = 'none';
      setStatus('');
    });
  })();
</script>
</Base>
