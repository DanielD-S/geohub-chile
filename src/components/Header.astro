---
interface Props {
  repoUrl?: string;
}
const { repoUrl = 'https://github.com/DanielD-S/geohub-chile' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname.replace(/\/$/, '');
const enHerramientas = path.includes('/herramientas');

// En la home las anclas funcionan como #seccion; desde otras páginas hay que
// volver a la home con la ancla absoluta.
const homeHref = (anchor: string) =>
  enHerramientas ? `${base}/${anchor}` : `#${anchor.replace(/^#/, '')}`;
---

<header>
  <div class="header-inner">
    <a href={`${base}/`} class="logo">
      <div class="logo-mark">G</div>
      <div class="logo-text">Geo<span>Hub</span>CL</div>
      <span class="logo-beta" title="En beta — el sitio puede tener cambios">BETA</span>
    </a>
    <nav class="header-nav">
      <a class={`hnav-link${!enHerramientas ? ' active' : ''}`} href={homeHref('#iniciativas')}>Comunidad</a>
      <a class="hnav-link" href={homeHref('#oficiales')}>Oficiales</a>
      <a class={`hnav-link${enHerramientas ? ' active' : ''}`} href={`${base}/herramientas/`}>Herramientas</a>
      <a class="hnav-link" href={homeHref('#fuentes')}>Fuentes</a>
      <a class="hnav-link" href={homeHref('#contribuir')}>Contribuir</a>
      <a class="hnav-link" href={homeHref('#apoyar')}>Apoyar</a>
      <a class="hnav-link" href={homeHref('#acerca')}>Acerca</a>
    </nav>
    <div class="header-right">
      <a class="btn-gh" href={repoUrl} target="_blank" rel="noopener">⬡ GitHub</a>
      {!enHerramientas && (
        <button class="btn-contribuir" data-modal-open>+ Añadir proyecto</button>
      )}
    </div>
  </div>
</header>

<script is:inline>
  // Scroll-spy solo aplica en la home (no en /herramientas/...)
  (() => {
    if (location.pathname.includes('/herramientas')) return;
    const secciones = ['iniciativas', 'oficiales', 'fuentes', 'contribuir', 'apoyar', 'acerca'];
    const navLinks = document.querySelectorAll('.hnav-link');
    window.addEventListener(
      'scroll',
      () => {
        const y = window.scrollY + 120;
        secciones.forEach((id) => {
          const el = document.getElementById(id);
          if (el && el.offsetTop <= y) {
            navLinks.forEach((l) => {
              if (l.getAttribute('href')?.endsWith('#' + id)) {
                navLinks.forEach((x) => x.classList.remove('active'));
                l.classList.add('active');
              }
            });
          }
        });
      },
      { passive: true }
    );
  })();
</script>
