---
import ArchivosPanel from './ArchivosPanel.astro';
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  iniciativa: CollectionEntry<'iniciativas'>;
}
const { iniciativa } = Astro.props;
const data = iniciativa.data;
const id = iniciativa.slug;

const catColors: Record<string, { bg: string; fg: string; border: string }> = {
  mineria:  { bg: 'rgba(245,197,24,0.12)', fg: 'var(--cat-mineria)', border: 'rgba(245,197,24,0.3)' },
  ambiental:{ bg: 'rgba(61,214,140,0.1)',  fg: 'var(--cat-amb)',     border: 'rgba(61,214,140,0.25)' },
  riesgo:   { bg: 'rgba(230,57,70,0.1)',   fg: 'var(--cat-riesgo)',  border: 'rgba(230,57,70,0.25)' },
  hidrico:  { bg: 'rgba(76,201,240,0.1)',  fg: 'var(--cat-hidro)',   border: 'rgba(76,201,240,0.25)' },
  social:   { bg: 'rgba(167,139,250,0.1)', fg: 'var(--cat-social)',  border: 'rgba(167,139,250,0.25)' },
  admin:    { bg: 'rgba(251,133,0,0.1)',   fg: 'var(--cat-admin)',   border: 'rgba(251,133,0,0.25)' },
  energia:  { bg: 'rgba(244,130,10,0.1)',  fg: 'var(--cat-energia)', border: 'rgba(244,130,10,0.25)' },
};
const catLabels: Record<string, string> = {
  mineria: 'Minería',
  ambiental: 'Ambiental',
  riesgo: 'Riesgos',
  hidrico: 'Hídrico',
  social: 'Social',
  admin: 'Admin. territorial',
  energia: 'Energía',
};
const c = catColors[data.categoria];
const iconoBg = data.iconoBg || c.bg;
const hasArchivos = !!data.archivos;

// Iconos SVG outline (estilo Lucide, MIT). Se eligen por slug y, si no
// hay match, caen a uno genérico por categoría. Color heredado vía
// `currentColor` para combinar con el badge de la categoría.
const ICONOS_SVG: Record<string, string> = {
  // Pickaxe estilizado (minería)
  'catastro-minero':
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 12 4 22.5"/><path d="M6 17h6"/><path d="M14.531 12.469 18 9c1.658-1.659 1.243-3.66 0-5l-1-1c-1.5-1.5-3.341-1.658-5 0L8.5 6.5"/><path d="M16 14 9 7"/></svg>',
  // Hoja (ambiental)
  'catastro-ambiental':
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96a1 1 0 0 1 1.8.7 53.4 53.4 0 0 1-2 12.84A7 7 0 0 1 11 20z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>',
  // Alert triangle (riesgos)
  'monitor-riesgos':
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><circle cx="12" cy="17" r="0.5" fill="currentColor"/></svg>',
  // Edificio (SII predios)
  'sii-predios':
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="1"/><path d="M8 7h2M14 7h2M8 11h2M14 11h2M8 15h2M14 15h2"/><path d="M10 21v-3h4v3"/></svg>',
  // Droplet (hídrico)
  'recursos-hidricos':
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>',
  // Mapa con divisiones (BCN)
  'limites-bcn':
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894L8.106 3.447a2 2 0 0 1 1.788 0z"/><path d="M9 4v13"/><path d="M15 7v13"/></svg>',
  // Globo (IDE Chile)
  'ide-chile':
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14.5 14.5 0 0 1 0 18M12 3a14.5 14.5 0 0 0 0 18"/></svg>',
};

// Fallback genérico por categoría si el slug no está mapeado arriba
const ICONOS_CAT: Record<string, string> = {
  mineria:   ICONOS_SVG['catastro-minero'],
  ambiental: ICONOS_SVG['catastro-ambiental'],
  riesgo:    ICONOS_SVG['monitor-riesgos'],
  hidrico:   ICONOS_SVG['recursos-hidricos'],
  admin:     ICONOS_SVG['limites-bcn'],
  social:    ICONOS_SVG['ide-chile'],
  energia:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
};
const iconoSvg = ICONOS_SVG[id] || ICONOS_CAT[data.categoria] || '';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// URLs relativas (./algo, /algo, algo.html) reciben prefijo de base. Absolutas pasan tal cual.
const resolveUrl = (u?: string) => {
  if (!u) return u;
  if (/^https?:\/\//i.test(u) || u.startsWith('mailto:') || u.startsWith('#')) return u;
  if (u.startsWith('./')) return `${base}/${u.slice(2)}`;
  if (u.startsWith('/'))  return `${base}${u}`;
  return `${base}/${u}`;
};

// URL del botón "👍 Valorar":
// - Si la iniciativa tiene `valoracionIssue: 42`, lleva a ese issue.
// - Si no, abre un issue nuevo pre-rellenado para crear el thread de valoración.
const repo = 'DanielD-S/geohub-chile';
const valoracionUrl = data.valoracionIssue
  ? `https://github.com/${repo}/issues/${data.valoracionIssue}`
  : (() => {
      const title = `[Valoración] ${data.nombre}`;
      const body = [
        `Hilo de valoración para **${data.nombre}** (\`${id}\`).`,
        '',
        'Reacciona con 👍 si esta iniciativa te resultó útil.',
        'Comenta si quieres aportar mejoras, reportar problemas o sugerir cambios.',
        '',
        '_Auto-generado al hacer clic en "Valorar" desde el sitio._',
      ].join('\n');
      const p = new URLSearchParams({ title, body, labels: 'valoracion' });
      return `https://github.com/${repo}/issues/new?${p.toString()}`;
    })();
---

<div class="iniciativa-card" data-cat={data.categoria} data-tags={data.tags}>
  <div class="card-top">
    <div class="card-icon" style={`background:${iconoBg};color:${c.fg}`}>
      <Fragment set:html={iconoSvg} />
    </div>
    <div class="card-body">
      <div class="card-meta">
        <span
          class="cat-badge"
          style={`background:${c.bg};color:${c.fg};border:1px solid ${c.border}`}
        >
          {catLabels[data.categoria]}
        </span>
        {data.categoriaExtra && (
          <span
            class="cat-badge"
            style={`background:rgba(76,201,240,0.08);color:${data.categoriaExtra.color};border:1px solid rgba(76,201,240,0.2);margin-left:2px`}
          >
            {data.categoriaExtra.label}
          </span>
        )}
        <span class="estado-badge">
          <span class={`estado-dot estado-${data.estado}`}></span>{data.estadoTexto}
        </span>
      </div>
      <div class="card-title-text">{data.nombre}</div>
      <p class="card-desc">{data.descripcion}</p>
    </div>
  </div>

  {data.capas.length > 0 && (
    <div class="capas-list">
      {data.capas.map((cap) => <span class="capa-tag">{cap}</span>)}
      {data.capasExtra && <span class="capa-tag-more">{data.capasExtra}</span>}
    </div>
  )}

  <div class="card-footer">
    {data.stats.map((s) =>
      s.valor ? (
        <span class="card-stat"><strong>{s.valor}</strong> {s.label}</span>
      ) : (
        <span class="card-stat">{s.label}</span>
      )
    )}
    <div class="card-actions">
      <a
        class="btn-card btn-card-valorar"
        href={valoracionUrl}
        target="_blank"
        rel="noopener"
        title="Valorar en GitHub (requiere cuenta)"
      >
        <Icon name="pulgar" size={13} /> {data.score > 0 ? data.score : ''}<span class="valorar-label">Valorar</span>
      </a>
      {data.acciones.map((a) => {
        if (a.tipo === 'ver' && hasArchivos) {
          return (
            <button class="btn-card btn-card-ver" data-toggle-archivos={id}>
              {a.texto} ▾
            </button>
          );
        }
        const cls =
          a.tipo === 'github'
            ? 'btn-card btn-card-gh'
            : a.tipo === 'ver'
              ? 'btn-card btn-card-ver'
              : a.tipo === 'externo'
                ? 'btn-card btn-card-externo'
                : 'btn-card btn-card-desc';
        return (
          <a class={cls} href={resolveUrl(a.url)} target="_blank" rel="noopener">{a.texto}</a>
        );
      })}
    </div>
  </div>

  {data.archivos && (
    <ArchivosPanel id={id} release={data.archivos.release} grupos={data.archivos.grupos} />
  )}
</div>
